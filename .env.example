# TopStep / Tradovate API Credentials
TOPSTEP_USERNAME=your_username
TOPSTEP_PASSWORD=your_password
TOPSTEP_APP_ID=your_app_id
TOPSTEP_APP_VERSION=1.0

# TradingView Security (Optional)
# If set, the webhook will check: "authorization": "Bearer <SECRET>"
TRADINGVIEW_SECRET=

# Database
DATABASE_URL=sqlite:///./topstepbot.db

# Server
PORT=8000
HOST=0.0.0.0
