# TopStep API Credentials
TOPSTEP_APIKEY=your_api_key
TOPSTEP_USERNAME=your_username

# Telegram Credentials
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_ID=your_telegram_id

# Ngrok Credentials
NGROK_AUTHTOKEN=your_ngrok_auth_token

# Database
DATABASE_URL=sqlite:///./topstepbot.db

# Server
PORT=8000
HOST=0.0.0.0

# Heartbeat Monitoring (Optional - for external monitoring like N8N)
# If set, the bot will send a POST request to this URL at the specified interval
# AUTH_TOKEN will be sent as "Authorization: Bearer <TOKEN>" header
HEARTBEAT_WEBHOOK_URL=https://your-monitoring.com/webhook
HEARTBEAT_INTERVAL_SECONDS=60
HEARTBEAT_AUTH_TOKEN=your_secret_token